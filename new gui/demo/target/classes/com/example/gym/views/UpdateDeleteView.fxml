<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gym.controllers.UpdateDeleteController"
            styleClass="modern-scroll" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">

    <VBox spacing="25">
        <padding><Insets top="10" right="10" bottom="30" left="10"/></padding>

        <VBox spacing="5">
            <Label text="✏️ Update &amp; Delete Operations" styleClass="page-header-white"/>
            <Label text="Modify member data and manage reservations and trainers" 
                   style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 14px;"/>
        </VBox>

        <HBox spacing="20">
            <VBox styleClass="content-card" spacing="20" HBox.hgrow="ALWAYS" prefWidth="400">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="25" fill="#ffd700"/>
                    <Label text="📧" style="-fx-font-size: 28px;"/>
                    <VBox>
                        <Label text="Update Member Email" styleClass="page-header"/>
                        <Label text="Change a member's email address" styleClass="info-label"/>
                    </VBox>
                </HBox>
                <Separator styleClass="modern-separator"/>
                <GridPane vgap="15" hgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="120"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                    <Label text="Member ID:" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="updateMemberIdField" promptText="e.g. 101" styleClass="modern-field" 
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <Label text="New Email:" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="newEmailField" promptText="e.g. newemail@example.com" styleClass="modern-field" 
                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                </GridPane>
                <Region VBox.vgrow="ALWAYS"/>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="💾 Update Email" styleClass="action-button" onAction="#updateMemberEmail"/>
                </HBox>
            </VBox>

            <VBox styleClass="content-card" spacing="20" HBox.hgrow="ALWAYS" prefWidth="400">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="25" fill="#00d26a"/>
                    <Label text="🔄" style="-fx-font-size: 28px;"/>
                    <VBox>
                        <Label text="Update Subscription" styleClass="page-header"/>
                        <Label text="Change subscription status" styleClass="info-label"/>
                    </VBox>
                </HBox>
                <Separator styleClass="modern-separator"/>
                <GridPane vgap="15" hgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="120"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                    <Label text="Subscription ID:" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="updateSubIdField" promptText="e.g. 201" styleClass="modern-field" 
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                    <Label text="New Status:" styleClass="form-label" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <ComboBox fx:id="statusComboBox" styleClass="modern-combo" 
                              GridPane.rowIndex="1" GridPane.columnIndex="1" promptText="Select status..."/>
                </GridPane>
                <Region VBox.vgrow="ALWAYS"/>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="💾 Update Status" styleClass="success-button" onAction="#updateSubscriptionStatus"/>
                </HBox>
            </VBox>
        </HBox>

        <HBox spacing="20">
            <VBox styleClass="content-card" spacing="20" HBox.hgrow="ALWAYS" prefWidth="400">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="25" fill="#ff4757"/>
                    <Label text="🗑️" style="-fx-font-size: 28px;"/>
                    <VBox>
                        <Label text="Delete Reservation" styleClass="page-header"/>
                        <Label text="Remove a reservation by ID" styleClass="info-label"/>
                    </VBox>
                </HBox>
                <Separator styleClass="modern-separator"/>
                <GridPane vgap="15" hgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="120"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                    <Label text="Reservation ID:" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="deleteResIdField" promptText="e.g. 301" styleClass="modern-field" 
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                </GridPane>
                <Label text="⚠️ This will also clear the session reference. This action cannot be undone!" 
                       wrapText="true" style="-fx-text-fill: #e94560; -fx-font-size: 11px;"/>
                <Region VBox.vgrow="ALWAYS"/>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="🗑️ Delete Reservation" styleClass="danger-button" onAction="#deleteReservation"/>
                </HBox>
            </VBox>

            <VBox styleClass="content-card" spacing="20" HBox.hgrow="ALWAYS" prefWidth="400">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="25" fill="#ff4757"/>
                    <Label text="🗑️" style="-fx-font-size: 28px;"/>
                    <VBox>
                        <Label text="Delete Trainer" styleClass="page-header"/>
                        <Label text="Remove a trainer by ID" styleClass="info-label"/>
                    </VBox>
                </HBox>
                <Separator styleClass="modern-separator"/>
                <GridPane vgap="15" hgap="10">
                    <columnConstraints>
                        <ColumnConstraints minWidth="100" prefWidth="120"/>
                        <ColumnConstraints hgrow="ALWAYS"/>
                    </columnConstraints>
                    <Label text="Trainer ID:" styleClass="form-label" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="deleteTrainerIdField" promptText="e.g. 501" styleClass="modern-field" 
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>
                </GridPane>
                <Label text="⚠️ This will permanently remove the trainer from the database. This action cannot be undone!" 
                       wrapText="true" style="-fx-text-fill: #e94560; -fx-font-size: 11px;"/>
                <Region VBox.vgrow="ALWAYS"/>
                <HBox spacing="10" alignment="CENTER_RIGHT">
                    <Button text="🗑️ Delete Trainer" styleClass="danger-button" onAction="#deleteTrainer"/>
                </HBox>
            </VBox>
        </HBox>

        <VBox fx:id="udNotificationBox" spacing="10" visible="false" managed="false">
            <Label fx:id="udNotificationLabel" styleClass="notification-text"/>
        </VBox>
    </VBox>
</ScrollPane>
