<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gym.controllers.AnalyticsController"
            styleClass="modern-scroll" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">

    <VBox spacing="25">
        <padding><Insets top="10" right="10" bottom="30" left="10"/></padding>

        <VBox spacing="5">
            <Label text="📈 Analytics Dashboard" styleClass="page-header-white"/>
            <Label text="Deep insights into your gym's performance" 
                   style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 14px;"/>
        </VBox>

        <HBox spacing="20">
            <VBox styleClass="stat-card" prefWidth="250" spacing="10">
                <Label text="📊" style="-fx-font-size: 32px;"/>
                <Label fx:id="totalRevenueLabel" text="$0" styleClass="stat-number"/>
                <Label text="ESTIMATED REVENUE" styleClass="stat-label"/>
            </VBox>
            <VBox styleClass="stat-card" prefWidth="250" spacing="10">
                <Label text="📈" style="-fx-font-size: 32px;"/>
                <Label fx:id="growthRateLabel" text="0%" styleClass="stat-number"/>
                <Label text="MEMBER GROWTH" styleClass="stat-label"/>
            </VBox>
            <VBox styleClass="stat-card" prefWidth="250" spacing="10">
                <Label text="🎯" style="-fx-font-size: 32px;"/>
                <Label fx:id="avgAttendanceLabel" text="0" styleClass="stat-number"/>
                <Label text="AVG DAILY CHECK-INS" styleClass="stat-label"/>
            </VBox>
            <VBox styleClass="stat-card" prefWidth="250" spacing="10">
                <Label text="⭐" style="-fx-font-size: 32px;"/>
                <Label fx:id="retentionRateLabel" text="0%" styleClass="stat-number"/>
                <Label text="RETENTION RATE" styleClass="stat-label"/>
            </VBox>
        </HBox>

        <HBox spacing="20" VBox.vgrow="ALWAYS">
            <VBox styleClass="content-card" spacing="15" HBox.hgrow="ALWAYS" prefWidth="400">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="15" fill="#e94560"/>
                    <Label text="🔥 Popular Disciplines" styleClass="page-header"/>
                </HBox>
                <Separator styleClass="modern-separator"/>
                <TableView fx:id="disciplineTable" styleClass="modern-table" prefHeight="250">
                    <columns>
                        <TableColumn text="Discipline" prefWidth="200"/>
                        <TableColumn text="Reservations" prefWidth="150"/>
                        <TableColumn text="Trend" prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>

            <VBox styleClass="content-card" spacing="15" HBox.hgrow="ALWAYS" prefWidth="400">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="15" fill="#00d26a"/>
                    <Label text="🏆 Trainer Leaderboard" styleClass="page-header"/>
                </HBox>
                <Separator styleClass="modern-separator"/>
                <TableView fx:id="trainerTable" styleClass="modern-table" prefHeight="250">
                    <columns>
                        <TableColumn text="Trainer" prefWidth="180"/>
                        <TableColumn text="Members" prefWidth="100"/>
                        <TableColumn text="Sessions" prefWidth="100"/>
                        <TableColumn text="Rating" prefWidth="100"/>
                    </columns>
                </TableView>
            </VBox>
        </HBox>

        <VBox styleClass="content-card-dark" spacing="15">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Circle radius="15" fill="#ffd700"/>
                <Label text="📍 Zone Utilization (Last Month)" styleClass="page-header-white"/>
            </HBox>
            <Separator styleClass="modern-separator" opacity="0.3"/>
            <TableView fx:id="zoneTable" styleClass="modern-table" prefHeight="200">
                <placeholder>
                    <Label text="Click 'Load Analytics' to populate data" 
                           style="-fx-text-fill: #adb5bd; -fx-font-size: 14px;"/>
                </placeholder>
            </TableView>
            <HBox alignment="CENTER_RIGHT">
                <Button text="🔄 Load Analytics" styleClass="action-button" onAction="#loadAnalytics"/>
            </HBox>
        </VBox>
    </VBox>
</ScrollPane>
