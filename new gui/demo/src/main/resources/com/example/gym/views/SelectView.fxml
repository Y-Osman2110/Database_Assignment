<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>
<?import javafx.scene.shape.*?>

<ScrollPane xmlns="http://javafx.com/javafx/17" xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.gym.controllers.SelectController"
            styleClass="modern-scroll" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED">

    <VBox spacing="25">
        <padding><Insets top="10" right="10" bottom="30" left="10"/></padding>

        <VBox spacing="5">
            <Label text="🔍 Search &amp; Query Operations" styleClass="page-header-white"/>
            <Label text="Search members, trainers, and run advanced queries" 
                   style="-fx-text-fill: rgba(255,255,255,0.7); -fx-font-size: 14px;"/>
        </VBox>

        <HBox spacing="20">
            <VBox styleClass="content-card" spacing="15" HBox.hgrow="ALWAYS" prefWidth="350">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="20" fill="#e94560"/>
                    <Label text="📱" style="-fx-font-size: 24px;"/>
                    <Label text="Find Member by Phone" styleClass="section-header"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="phoneSearchField" promptText="Enter phone number..." 
                               styleClass="modern-field" HBox.hgrow="ALWAYS"/>
                    <Button text="🔍 Search" styleClass="action-button" onAction="#findMemberByPhone"/>
                </HBox>
                <TextArea fx:id="phoneResultArea" editable="false" 
                          styleClass="modern-textarea" prefRowCount="4"
                          promptText="Results will appear here..."/>
            </VBox>

            <VBox styleClass="content-card" spacing="15" HBox.hgrow="ALWAYS" prefWidth="350">
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Circle radius="20" fill="#ffd700"/>
                    <Label text="🏋️" style="-fx-font-size: 24px;"/>
                    <Label text="Find Trainer by Specialty" styleClass="section-header"/>
                </HBox>
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <TextField fx:id="specialtySearchField" promptText="e.g. Yoga, CrossFit..." 
                               styleClass="modern-field" HBox.hgrow="ALWAYS"/>
                    <Button text="🔍 Search" styleClass="action-button" onAction="#findTrainerBySpecialty"/>
                </HBox>
                <TextArea fx:id="specialtyResultArea" editable="false" 
                          styleClass="modern-textarea" prefRowCount="4"
                          promptText="Results will appear here..."/>
            </VBox>
        </HBox>

        <VBox styleClass="content-card-dark" spacing="20">
            <HBox alignment="CENTER_LEFT" spacing="10">
                <Circle radius="20" fill="#00d26a"/>
                <Label text="📊" style="-fx-font-size: 24px;"/>
                <Label text="Quick Queries &amp; Reports" styleClass="page-header-white"/>
            </HBox>

            <Separator styleClass="modern-separator" opacity="0.3"/>

            <FlowPane hgap="15" vgap="15">
                <Button text="📅 Expired Subscriptions" styleClass="secondary-button" onAction="#getExpiredSubscriptions"/>
                <Button text="📋 Trainer Schedules" styleClass="secondary-button" onAction="#getTrainerSchedule"/>
                <Button text="🔥 Max Reservations Discipline" styleClass="secondary-button" onAction="#getDisciplineMaxReservation"/>
                <Button text="📭 Empty Sessions (Last Month)" styleClass="secondary-button" onAction="#getSessionsNoReservations"/>
                <Button text="🏆 Top Trainer (Attendance)" styleClass="secondary-button" onAction="#getTopTrainer"/>
                <Button text="😴 Inactive Active Members" styleClass="secondary-button" onAction="#getInactiveActiveMembers"/>
                <Button text="📍 Sessions Per Zone" styleClass="secondary-button" onAction="#getSessionsPerZone"/>
                <Button text="📈 Members Total Reservations" styleClass="secondary-button" onAction="#getMembersTotalReservations"/>
            </FlowPane>

            <TableView fx:id="resultsTable" styleClass="modern-table" prefHeight="300">
                <placeholder>
                    <Label text="Run a query to see results here..." 
                           style="-fx-text-fill: #adb5bd; -fx-font-size: 14px;"/>
                </placeholder>
            </TableView>
        </VBox>
    </VBox>
</ScrollPane>
